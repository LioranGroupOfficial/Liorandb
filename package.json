{
  "name": "@liorandb/core",
  "version": "1.0.12",
  "description": "**LioranDB Core Module** – Lightweight, local-first, peer-to-peer database management for Node.js.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts src/worker/dbWorker.ts --dts --format esm",
    "prepublishOnly": "npm run build"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LioranGroupOfficial/Liorandb.git"
  },
  "keywords": [],
  "author": "LioranGroup",
  "license": "LDEP",
  "type": "module",
  "bugs": {
    "url": "https://github.com/LioranGroupOfficial/Liorandb/issues"
  },
  "homepage": "https://github.com/LioranGroupOfficial/Liorandb#readme",
  "dependencies": {
    "classic-level": "^3.0.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
