{
  "name": "@liorandb/core",
  "version": "1.1.12",
  "description": "LioranDB Core Module – Lightweight, local-first, peer-to-peer database management for Node.js.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node __tests__/compaction.test.mjs && node __tests__/wal-recovery.test.mjs && node __tests__/backpressure.test.mjs && node __tests__/chunked-inserts.test.mjs && node __tests__/indexing.test.mjs",
    "test:compact": "node __tests__/compaction.test.mjs",
    "prepublishOnly": "npm run build"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LioranGroupOfficial/Liorandb.git"
  },
  "keywords": [
    "p2p-database",
    "lioran",
    "liorandb",
    "p2p-db",
    "peer-to-peer-db",
    "peer-to-peer-database",
    "localfirst-db",
    "localfirst-database"
  ],
  "author": "LioranGroup",
  "license": "LDEP",
  "type": "module",
  "bugs": {
    "url": "https://github.com/LioranGroupOfficial/Liorandb/issues"
  },
  "homepage": "https://db.lioransolutions.com/",
  "dependencies": {
    "@types/tar-stream": "^3.1.4",
    "classic-level": "^3.0.0",
    "tar": "^7.5.9",
    "tar-stream": "^3.1.7",
    "uuid": "^14.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
