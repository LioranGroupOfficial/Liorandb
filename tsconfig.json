{
  "compilerOptions": {
    "target": "ES2022",

    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "rootDir": "src",
    "outDir": "dist",

    "baseUrl": ".",               // REQUIRED when using paths
    "paths": {
      "@/*": ["src/*"]
    },

    "ignoreDeprecations": "6.0",  // Silences node10 deprecation warning

    "declaration": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src"]
}