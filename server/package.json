{
  "name": "@liorandb/db",
  "version": "1.1.10",
  "description": "LioranDB server and CLI",
  "main": "dist/server.js",
  "bin": {
    "ldb-cli": "dist/cli/index.js",
    "ldb": "dist/cli/ldb.js",
    "ldb-users": "dist/cli/users.js",
    "ldb-serve": "dist/server.js"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "build:exe": "node build-exe.js",
    "start": "node dist/server.js",
    "cli": "ts-node src/cli/index.ts",
    "users": "ts-node src/cli/users.ts"
  },
  "files": [
    "dist",
    "public"
  ],
  "keywords": [
    "database",
    "liorandb",
    "server",
    "cli"
  ],
  "author": "Lioran Group",
  "license": "LDEP",
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/commander": "^2.12.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.0.1",
    "commander": "^14.0.2",
    "nexe": "^5.0.0-beta.4",
    "nodemon": "^3.1.11",
    "pkg": "^5.8.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@liorandb/core": "^1.1.12",
    "@liorandb/driver": "^1.1.5",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "postject": "^1.0.0-alpha.6",
    "resedit": "^3.0.2"
  }
}
